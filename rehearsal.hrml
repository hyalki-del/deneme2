<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <meta name="theme-color" content="#0a0a0c">
  <title>Show Mode — Setlist Builder</title>

  <!-- Typography & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Oswald:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Shared Design Engine -->
  <link rel="stylesheet" href="css/style.css">

  <style>
    .rehearsal-container {
      max-width: 1200px;
      margin: 120px auto 60px auto;
      padding: 0 24px;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      flex-wrap: wrap;
      gap: 16px;
    }

    .page-title {
      font-family: var(--font-display);
      font-size: 2.5rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    /* 2-Column Responsive Layout */
    .setlist-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }

    @media (max-width: 768px) {
      .setlist-grid {
        grid-template-columns: 1fr;
      }
    }

    .column-panel {
      background: var(--bg-card);
      border: 1px solid var(--border-dark);
      border-radius: var(--radius-md);
      padding: 20px;
      min-height: 500px;
      display: flex;
      flex-direction: column;
      backdrop-filter: blur(8px);
    }

    .column-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-bottom: 16px;
      margin-bottom: 16px;
      border-bottom: 1px solid var(--border-dark);
    }

    .column-header h2 {
      font-family: var(--font-display);
      font-size: 1.4rem;
      text-transform: uppercase;
      color: var(--text-main);
    }

    .song-stack {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
      flex-grow: 1;
    }

    .song-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-dark);
      border-radius: var(--radius-sm);
      padding: 12px 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      user-select: none;
      transition: all var(--transition-fast);
    }

    .song-card:hover {
      border-color: var(--border-red);
      transform: translateX(4px);
    }

    .rhs-card:hover {
      border-color: #00bbff;
      transform: translateX(-4px);
    }

    .song-details {
      display: flex;
      flex-direction: column;
    }

    .song-title-text {
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--text-main);
    }

    .song-artist-text {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    .key-tag {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--accent-red);
      background: rgba(211, 16, 16, 0.1);
      padding: 4px 8px;
      border-radius: 4px;
    }

    .badge-counter {
      background: var(--accent-red);
      color: #fff;
      font-size: 0.8rem;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 12px;
    }
  </style>
</head>
<body class="no-select">

  <!-- Navigation Bar -->
  <header>
    <nav class="navbar">
      <a href="index.html" class="brand-logo" id="navLogo">BR</a>
      <ul class="nav-links">
        <li><a href="index.html">Overview</a></li>
        <li><a href="playlist.html">Repertoire</a></li>
        <li><a href="calendar.html">Schedule</a></li>
        <li><a href="admin.html">Members</a></li>
        <li><a href="fan.html">Encore Game</a></li>
      </ul>
      <a href="rehearsal.html" class="btn-sign-in">SHOW MODE</a>
    </nav>
  </header>

  <!-- Rehearsal / Show Workspace -->
  <main class="rehearsal-container">
    
    <div class="page-header">
      <h1 class="page-title">SETLIST BUILDER</h1>
      <div style="display: flex; gap: 12px;">
        <button class="btn-primary" style="background: #0077ff; box-shadow: 0 4px 16px rgba(0,119,255,0.3);" onclick="pickRandomTrack()">
          <i class="fa-solid fa-dice" style="margin-right: 8px;"></i> PICK RANDOM
        </button>
        <button class="btn-primary" onclick="generatePrintableSetlist()">
          <i class="fa-solid fa-print" style="margin-right: 8px;"></i> PRINT SETLIST
        </button>
      </div>
    </div>

    <!-- Two Column Interactive Layout -->
    <div class="setlist-grid">
      
      <!-- Left Column: Available Repertoire -->
      <section class="column-panel">
        <div class="column-header">
          <h2>AVAILABLE TRACKS</h2>
          <span class="badge-counter" id="lhsCount">0</span>
        </div>
        <ul id="lhsList" class="song-stack">
          <!-- Dynamically populated -->
        </ul>
      </section>

      <!-- Right Column: Selected Setlist -->
      <section class="column-panel">
        <div class="column-header">
          <h2>PICKED SETLIST</h2>
          <span class="badge-counter" id="rhsCount" style="background:#00bbff;">0</span>
        </div>
        <ul id="rhsList" class="song-stack">
          <!-- Dynamically populated -->
        </ul>
      </section>

    </div>
  </main>

  <!-- JS Dependencies -->
  <script src="js/config.js"></script>
  <script src="js/api.js"></script>

  <script>
    let lhsSongs = [];
    let rhsSongs = [];

    document.addEventListener("DOMContentLoaded", async () => {
      await loadRepertoire();
    });

    async function loadRepertoire() {
      try {
        const fullPlaylist = await ApiService.getPlaylist();
        
        // Fallback testing data if database is unpopulated
        if (!fullPlaylist || fullPlaylist.length === 0) {
          lhsSongs = [
            { id: "1", title: "Master of Puppets", artist: "Metallica", musicalKey: "E" },
            { id: "2", title: "Hotel California", artist: "Eagles", musicalKey: "Bm" },
            { id: "3", title: "Comfortably Numb", artist: "Pink Floyd", musicalKey: "Bm" },
            { id: "4", title: "Sweet Child O Mine", artist: "Guns N Roses", musicalKey: "Db" }
          ];
        } else {
          lhsSongs = [...fullPlaylist];
        }
        renderColumns();
      } catch (err) {
        console.error("Failed to load rehearsal data:", err);
      }
    }

    function renderColumns() {
      const lhsEl = document.getElementById('lhsList');
      const rhsEl = document.getElementById('rhsList');
      
      document.getElementById('lhsCount').textContent = lhsSongs.length;
      document.getElementById('rhsCount').textContent = rhsSongs.length;

      lhsEl.innerHTML = '';
      rhsEl.innerHTML = '';

      // Render Available Songs (LHS)
      lhsSongs.forEach((song, idx) => {
        const li = document.createElement('li');
        li.className = 'song-card';
        li.innerHTML = `
          <div class="song-details">
            <span class="song-title-text">${song.title}</span>
            <span class="song-artist-text">${song.artist}</span>
          </div>
          <span class="key-tag">${song.musicalKey}</span>
        `;
        // Single click moves from LHS -> RHS
        li.onclick = () => moveToRHS(idx);
        lhsEl.appendChild(li);
      });

      // Render Picked Setlist (RHS)
      rhsSongs.forEach((song, idx) => {
        const li = document.createElement('li');
        li.className = 'song-card rhs-card';
        li.innerHTML = `
          <div class="song-details">
            <span class="song-title-text">${idx + 1}. ${song.title}</span>
            <span class="song-artist-text">${song.artist}</span>
          </div>
          <span class="key-tag" style="color:#00bbff; background:rgba(0,187,255,0.1);">${song.musicalKey}</span>
        `;
        // Double click moves from RHS -> LHS
        li.ondblclick = () => moveToLHS(idx);
        rhsEl.appendChild(li);
      });
    }

    function moveToRHS(index) {
      rhsSongs.push(lhsSongs[index]);
      lhsSongs.splice(index, 1);
      renderColumns();
    }

    function moveToLHS(index) {
      lhsSongs.push(rhsSongs[index]);
      rhsSongs.splice(index, 1);
      renderColumns();
    }

    function pickRandomTrack() {
      if (lhsSongs.length === 0) {
        alert("All tracks are already added to the setlist!");
        return;
      }
      const randomIndex = Math.floor(Math.random() * lhsSongs.length);
      moveToRHS(randomIndex);
    }

    function generatePrintableSetlist() {
      if (rhsSongs.length === 0) {
        alert("Add songs to the picked setlist first before printing.");
        return;
      }

      const bandTitle = typeof BAND_CONFIG !== "undefined" ? BAND_CONFIG.bandName : "SHOW SETLIST";
      const dateStr = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
      
      const printWin = window.open("", "_blank");
      printWin.document.write(`
        <html>
          <head>
            <title>${bandTitle} - Setlist (${dateStr})</title>
            <style>
              body {
                background-color: #ffffff;
                color: #000000;
                font-family: 'Courier New', Courier, monospace;
                padding: 60px;
              }
              .header {
                text-align: center;
                border-bottom: 3px solid #000000;
                padding-bottom: 12px;
                margin-bottom: 36px;
              }
              h1 { font-size: 32px; margin: 0; text-transform: uppercase; }
              h3 { font-size: 16px; margin-top: 8px; color: #444; }
              ol { font-size: 22px; line-height: 2.2; padding-left: 40px; }
              li strong { font-size: 24px; }
              .key-indicator { float: right; font-weight: bold; }
            </style>
          </head>
          <body>
            <div class="header">
              <h1>${bandTitle}</h1>
              <h3>SHOW SETLIST — ${dateStr}</h3>
            </div>
            <ol>
              ${rhsSongs.map(song => `
                <li>
                  <strong>${song.title}</strong> (${song.artist})
                  <span class="key-indicator">[ KEY: ${song.musicalKey} ]</span>
                </li>
              `).join('')}
            </ol>
            <script>
              window.onload = function() {
                window.print();
              };
            <\/script>
          </body>
        </html>
      `);
    }
  </script>
</body>
</html>
